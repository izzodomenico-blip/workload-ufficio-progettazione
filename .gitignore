*.xml
*.xls
*.xlsx

# Config admin (contiene hash password baseline workload)
server/admin.config.json
# Config sezione Consuntivi (hash password dedicata Prezzi/Report)
server/consuntivi.config.json

# Output cache del tool graphify (generato, non sorgente)
graphify-out/

# Pacchetti server generati e backup off-site (non vanno nel repo)
workload-server-*.zip
backups/offsite/
